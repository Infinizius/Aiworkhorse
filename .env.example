# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- Database ---
POSTGRES_USER=workhorse
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=workhorse_db

# --- AI-Workhorse Blueprint v8.1: Regel 7 (Getrennte Iterations-Limits) ---
# Schutz vor Endlosschleifen im Chat
REACTIVE_MAX_ITERATIONS=3
# Für die spätere autonome Goal-Engine (Phase 2)
GOAL_MAX_ITERATIONS=10

# --- Web-Search Tool (optional) ---
# If set, Serper API is used for web search; otherwise DuckDuckGo is the fallback.
# Get a free API key at https://serper.dev
SERPER_API_KEY=

# --- Open WebUI ---
# Secret key for Open WebUI session signing. Change before going to production.
WEBUI_SECRET_KEY=CHANGE_ME_STRONG_SECRET

# --- Frontend (Next.js) ---
# URL of the FastAPI backend, accessible from the browser.
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL of the Open WebUI chat interface.
NEXT_PUBLIC_OPEN_WEBUI_URL=http://localhost:3002

# --- CORS ---
# Comma-separated list of origins allowed to call the FastAPI backend.
# Add the URL of the Next.js dashboard (default: http://localhost:3001 for dev)
# alongside the Open WebUI URL (http://localhost:3002).
CORS_ALLOW_ORIGINS=http://localhost:3002,http://localhost:3001
